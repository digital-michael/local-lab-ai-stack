# Caddy — photondatum.space
# Deploy at:  /etc/caddy/Caddyfile on the photondatum server
# Validate:   sudo caddy validate --config /etc/caddy/Caddyfile
# Reload:     sudo systemctl reload caddy
# Logs:       sudo journalctl -u caddy -f
#
# TLS: Automatic via Let's Encrypt (TLS-ALPN-01 on :443).
#      Caddy owns both :80 (HTTP→HTTPS redirects) and :443 (content + TLS).
#      Static site blocks use bare hostnames — Caddy serves :443 and auto-redirects :80.
#      Service blocks use https:// prefix — HTTPS-only, no HTTP redirect needed.
#
# Backend: CENTAURI at tailnet IP 100.64.0.4:443 via WireGuard.
#   Traefik presents a self-signed *.stack.localhost cert; tls_insecure_skip_verify
#   is required. Transport security is provided by WireGuard.
#
# Host header: when the upstream is an IP+TLS address, Caddy sets Host to the IP.
#   Each CENTAURI block uses header_up Host to set the value Traefik expects.
#
# SSO: chat.photondatum.space bypasses Authentik — the outpost External URL is
#   auth.stack.localhost (LAN-only). OpenWebUI's own auth handles external access.

# ══════════════════════════════════════════════════════════════════════════════
# Static site — served by Caddy's file_server on :80 and :443
# ══════════════════════════════════════════════════════════════════════════════

photondatum.space {
    root * /var/www/photondatum
    file_server
}

mail.photondatum.space {
    root * /var/www/photondatum
    file_server
}

# ══════════════════════════════════════════════════════════════════════════════
# Local services — running on photondatum.space itself
# ══════════════════════════════════════════════════════════════════════════════

# ── Headscale coordination server + embedded DERP relay ──────────────────────
# Two HTTP/2 issues must both be fixed for DERP relay to work:
#   1. Frontend ALPN: tls { alpn http/1.1 } — prevents Caddy negotiating h2 with clients.
#   2. Backend transport: versions 1.1 — prevents Caddy using h2 to Headscale.
https://headscale.photondatum.space {
    tls {
        alpn http/1.1
    }
    reverse_proxy 127.0.0.1:8080 {
        transport http {
            versions 1.1
        }
    }
}

# ── Forgejo — git hosting ─────────────────────────────────────────────────────
https://git.photondatum.space {
    reverse_proxy 127.0.0.1:3000
}

# ══════════════════════════════════════════════════════════════════════════════
# CENTAURI services — proxied over WireGuard tailnet to 100.64.0.4:443
# ══════════════════════════════════════════════════════════════════════════════

# ── Authentik SSO ─────────────────────────────────────────────────────────────
https://auth.photondatum.space {
    reverse_proxy 100.64.0.4:443 {
        header_up Host auth.stack.localhost
        transport http {
            tls_insecure_skip_verify
        }
    }
}

# ── OpenWebUI — AI chat interface ─────────────────────────────────────────────
https://chat.photondatum.space {
    reverse_proxy 100.64.0.4:443 {
        header_up Host chat.photondatum.space
        transport http {
            tls_insecure_skip_verify
        }
    }

    handle_errors {
        respond "AI Stack is currently offline. Services will resume when the controller comes back online." 503
    }
}

# ── Additional CENTAURI services — uncomment to expose ───────────────────────
# Pattern: header_up Host to the *.stack.localhost Traefik router for the service.

