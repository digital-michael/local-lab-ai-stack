# Caddy reverse proxy — photondatum.space / photondatum.com
# Deploy at:  /etc/caddy/Caddyfile on the photondatum server
# Validate:   sudo caddy validate --config /etc/caddy/Caddyfile
# Reload:     sudo systemctl reload caddy
# Logs:       sudo journalctl -u caddy -f
#
# TLS: Automatic via TLS-ALPN-01 on port 443. Caddy does NOT bind port 80.
#      auto_https disable_redirects suppresses Caddy's built-in HTTP redirect
#      server, freeing port 80 for nginx to serve the static root site.
#      nginx handles HTTP; Caddy handles HTTPS only.
#
# Backend: CENTAURI at tailnet IP 100.64.0.4:443 via WireGuard.
#   Traefik is bound to 0.0.0.0:443 on CENTAURI and is reachable at this IP.
#   Traefik presents a self-signed *.stack.localhost cert on all connections;
#   tls_insecure_skip_verify is required. Transport security is provided by WireGuard.
#
# Routing: When the upstream is an IP address with TLS, Caddy sets the Host header to
#   the upstream IP, not the original hostname. Each block must use header_up Host to
#   set the correct value so Traefik's router rules match.
#   - auth, flowise, grafana, etc.: header_up Host <service>.stack.localhost (existing routers)
#   - chat: header_up Host chat.photondatum.space (openwebui-public router, no Authentik)
#
# SSO: chat.photondatum.space bypasses Authentik forwardAuth — the outpost External URL is
#   auth.stack.localhost (LAN-only), so forwardAuth would redirect external browsers to an
#   unresolvable domain. OpenWebUI's own auth handles external access instead.
#   See §7.15 of CENTAURI-playbook.md for the full SSO architecture.

{
    # Caddy does NOT bind port 80. nginx owns port 80 for HTTP.
    # Certs are obtained via TLS-ALPN-01 on port 443 only.
    auto_https disable_redirects
}

# ── Root domain — static site (HTTPS; nginx owns HTTP on port 80) ────────────
# Caddy serves HTTPS for this domain directly via file_server.
# nginx on port 80 handles HTTP for the same content.
# Update root path to match the actual document root on this server.
photondatum.space {
    root * /var/www/photondatum
    file_server
}

# ── Headscale coordination server + embedded DERP relay ──────────────────────
# Nodes enroll via: tailscale up --login-server https://headscale.photondatum.space
# Headscale listens on 127.0.0.1:8080; Caddy provides TLS termination.
# Embedded DERP is served at https://headscale.photondatum.space/derp — no separate
# derp.* block needed. STUN (UDP 3478) is handled directly by Headscale.
#
# Two HTTP/2 issues must both be addressed for DERP relay to work:
#   1. Frontend ALPN: Caddy must offer only http/1.1 to clients (tls { alpn http/1.1 }).
#      If h2 is negotiated, Tailscale clients can't do the HTTP Upgrade to start DERP.
#   2. Backend transport: Caddy must use HTTP/1.1 to Headscale (transport http { versions 1.1 }).
#      Both are required; fixing only one is not sufficient.
headscale.photondatum.space {
    tls {
        alpn http/1.1
    }

    # Root path has no content — return 404 rather than an empty 200.
    # All Headscale API paths (/key, /register, /oidc/*, /derp, /health) fall
    # through to the reverse_proxy block below.
    @root path /
    handle @root {
        respond "Not Found" 404
    }

    handle {
        reverse_proxy 127.0.0.1:8080 {
            transport http {
                versions 1.1
            }
        }
    }
}

# ── Authentik SSO — required for external auth flow ──────────────────────────
auth.photondatum.space {
    reverse_proxy 100.64.0.4:443 {
        header_up Host auth.stack.localhost
        transport http {
            tls_insecure_skip_verify
        }
    }
}

# ── OpenWebUI — primary AI chat interface ────────────────────────────────────
# Host header is NOT rewritten: Traefik matches the dedicated openwebui-public router
# (Host: chat.photondatum.space) which intentionally omits the authentik middleware.
# The Authentik outpost External URL is auth.stack.localhost (LAN-only); forwardAuth
# would redirect external browsers to an unresolvable domain.
# OpenWebUI's own authentication handles external user access.
chat.photondatum.space {
    reverse_proxy 100.64.0.4:443 {
        # Caddy sets Host to the upstream IP when the backend is an IP+TLS address.
        # Explicitly restore it so Traefik matches the openwebui-public router.
        header_up Host chat.photondatum.space
        transport http {
            tls_insecure_skip_verify
        }
    }

    handle_errors {
        respond "AI Stack is currently offline. Services will resume when the controller comes back online." 503
    }
}

# ══════════════════════════════════════════════════════════════════════════════
# photondatum.com — public entry point (Let's Encrypt via TLS-ALPN-01)
# ══════════════════════════════════════════════════════════════════════════════

# ── Root domain — static site (HTTPS; nginx owns HTTP on port 80) ────────────
photondatum.com {
    root * /var/www/photondatum
    file_server
}

# ── Authentik SSO ─────────────────────────────────────────────────────────────
# Host is rewritten to auth.stack.localhost so the existing Traefik router matches.
# No new Traefik router needed.
auth.photondatum.com {
    reverse_proxy 100.64.0.4:443 {
        header_up Host auth.stack.localhost
        transport http {
            tls_insecure_skip_verify
        }
    }
}

# ── OpenWebUI — primary AI chat interface ─────────────────────────────────────
# Host is NOT rewritten: Traefik matches the openwebui-public-com router
# (Host: chat.photondatum.com) which intentionally omits the authentik middleware.
# OpenWebUI's own authentication handles external user access.
chat.photondatum.com {
    reverse_proxy 100.64.0.4:443 {
        header_up Host chat.photondatum.com
        transport http {
            tls_insecure_skip_verify
        }
    }

    handle_errors {
        respond "AI Stack is currently offline. Services will resume when the controller comes back online." 503
    }
}

# ── Additional services — uncomment to expose ────────────────────────────────
# Pattern: pick a subdomain, rewrite Host to the *.stack.localhost entry in
# configs/traefik/dynamic/services.yaml. No Traefik changes required.

