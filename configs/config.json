{
  "schema_version": "1.2",
  "ai_stack_dir": "$HOME/ai-stack",
  "network": {
    "name": "ai-stack-net",
    "driver": "bridge",
    "internal": false
  },
  "node_profile": "controller",
  "sleep_inhibit": false,
  "models": [
    {
      "name": "llama3.1:8b",
      "backend": "ollama",
      "device": "gpu",
      "num_gpu": -1,
      "description": "8B — full GPU (RTX 3070 Ti)"
    },
    {
      "name": "qwen3.5:4b",
      "backend": "ollama",
      "device": "gpu",
      "num_gpu": -1,
      "description": "4.7B — full GPU (RTX 3070 Ti)"
    },
    {
      "name": "qwen3:8b",
      "backend": "ollama",
      "device": "gpu",
      "num_gpu": -1,
      "description": "8B — full GPU (RTX 3070 Ti)"
    },
    {
      "name": "llama3.2:3b",
      "backend": "ollama",
      "device": "gpu",
      "num_gpu": -1,
      "description": "3B — full GPU (RTX 3070 Ti)"
    },
    {
      "name": "qwen2.5-1.5b",
      "backend": "vllm",
      "device": "gpu",
      "repo": "Qwen/Qwen2.5-1.5B-Instruct",
      "quantization": null
    },
    {
      "name": "llama3.1:8b-instruct-q4_K_M",
      "backend": "ollama",
      "device": "gpu",
      "host": "macbook-m1"
    },
    {
      "name": "llama3.2:3b-instruct-q4_K_M",
      "backend": "ollama",
      "device": "gpu",
      "host": "alienware"
    },
    {
      "name": "gpt-4o",
      "backend": "openai",
      "api_key_secret": "openai_api_key"
    },
    {
      "name": "llama3-70b-8192",
      "backend": "groq",
      "api_key_secret": "groq_api_key"
    },
    {
      "name": "claude-sonnet-4-5",
      "backend": "anthropic",
      "api_key_secret": "anthropic_api_key"
    },
    {
      "name": "mistral-large-latest",
      "backend": "mistral",
      "api_key_secret": "mistral_api_key"
    }
  ],
  "services": {
    "traefik": {
      "image": "docker.io/library/traefik",
      "tag": "v3.6.10",
      "container_name": "traefik",
      "dns_alias": "traefik.ai-stack",
      "depends_on": [],
      "ports": [
        {
          "host": 80,
          "container": 80,
          "bind": "0.0.0.0"
        },
        {
          "host": 443,
          "container": 443,
          "bind": "0.0.0.0"
        },
        {
          "host": 8080,
          "container": 8080,
          "bind": "127.0.0.1"
        },
        {
          "host": 8443,
          "container": 8443,
          "bind": "100.64.0.4"
        }
      ],
      "volumes": [
        {
          "host": "$AI_STACK_DIR/configs/traefik/traefik.yaml",
          "container": "/etc/traefik/traefik.yaml",
          "mode": "ro"
        },
        {
          "host": "$AI_STACK_DIR/configs/traefik/dynamic",
          "container": "/etc/traefik/dynamic",
          "mode": "ro"
        },
        {
          "host": "$AI_STACK_DIR/configs/tls",
          "container": "/etc/traefik/tls",
          "mode": "ro"
        }
      ],
      "environment": {},
      "secrets": [],
      "health_check": {
        "command": "wget -qO- http://localhost:8080/ping || exit 1",
        "interval": "30s",
        "retries": 3,
        "timeout": "5s"
      },
      "resources": {
        "cpus": 0.5,
        "memory": "256m",
        "gpu": null
      }
    },
    "postgres": {
      "image": "docker.io/library/postgres",
      "tag": "17.9",
      "container_name": "postgres",
      "dns_alias": "postgres.ai-stack",
      "depends_on": [],
      "ports": [
        {
          "host": 5432,
          "container": 5432,
          "bind": "127.0.0.1"
        }
      ],
      "volumes": [
        {
          "host": "$AI_STACK_DIR/postgres",
          "container": "/var/lib/postgresql/data",
          "mode": "rw"
        }
      ],
      "environment": {
        "POSTGRES_USER": "aistack",
        "POSTGRES_DB": "aistack"
      },
      "secrets": [
        {
          "name": "postgres_password",
          "target": "POSTGRES_PASSWORD"
        }
      ],
      "health_check": {
        "command": "pg_isready -U aistack",
        "interval": "30s",
        "retries": 3,
        "timeout": "5s"
      },
      "resources": {
        "cpus": 2,
        "memory": "4g",
        "gpu": null
      }
    },
    "qdrant": {
      "image": "docker.io/qdrant/qdrant",
      "tag": "v1.17.0",
      "container_name": "qdrant",
      "dns_alias": "qdrant.ai-stack",
      "depends_on": [],
      "ports": [],
      "volumes": [
        {
          "host": "$AI_STACK_DIR/qdrant",
          "container": "/qdrant/storage",
          "mode": "rw"
        }
      ],
      "environment": {},
      "secrets": [
        {
          "name": "qdrant_api_key",
          "target": "QDRANT__SERVICE__API_KEY"
        }
      ],
      "health_check": {
        "command": "bash -c 'echo > /dev/tcp/localhost/6333'",
        "interval": "30s",
        "retries": 3,
        "timeout": "5s"
      },
      "resources": {
        "cpus": 2,
        "memory": "8g",
        "gpu": null
      }
    },
    "knowledge-index": {
      "image": "localhost/knowledge-index",
      "tag": "0.1.0",
      "container_name": "knowledge-index",
      "dns_alias": "knowledge-index.ai-stack",
      "depends_on": [
        "postgres",
        "qdrant"
      ],
      "ports": [
        {
          "host": 8100,
          "container": 8100,
          "bind": "127.0.0.1"
        }
      ],
      "volumes": [
        {
          "host": "$AI_STACK_DIR/libraries",
          "container": "/libraries",
          "mode": "ro"
        },
        {
          "host": "$AI_STACK_DIR/test-tmp",
          "container": "/test-tmp",
          "mode": "rw"
        }
      ],
      "environment": {
        "DATABASE_URL": "postgresql://aistack:@postgres.ai-stack:5432/aistack",
        "QDRANT_HOST": "qdrant.ai-stack",
        "QDRANT_PORT": "6333",
        "ROUTE_CACHE_TTL": "60",
        "LISTEN_PORT": "8100",
        "NODE_PROFILE": "controller",
        "TAILNET_CONTROLLER_URL": "https://100.64.0.4:8443",
        "TAILNET_DOMAIN": "ecotone-000-01"
      },
      "secrets": [
        {
          "name": "postgres_password",
          "target": "POSTGRES_PASSWORD"
        },
        {
          "name": "qdrant_api_key",
          "target": "QDRANT_API_KEY"
        },
        {
          "name": "knowledge_index_api_key",
          "target": "API_KEY"
        },
        {
          "name": "minio_ki_access_key",
          "target": "MINIO_ACCESS_KEY"
        },
        {
          "name": "minio_ki_secret_key",
          "target": "MINIO_SECRET_KEY"
        },
        {
          "name": "knowledge_index_cnc_token",
          "target": "CNC_BEARER_TOKEN"
        }
      ],
      "health_check": {
        "command": "bash -c 'echo > /dev/tcp/localhost/8100'",
        "interval": "30s",
        "retries": 3,
        "timeout": "5s"
      },
      "mcp": {
        "sse_endpoint": "/mcp/sse",
        "message_endpoint": "/mcp/messages",
        "tools": [
          "search_knowledge",
          "ingest_document"
        ],
        "transport": "http-sse"
      },
      "resources": {
        "cpus": 1,
        "memory": "512m",
        "gpu": null
      }
    },
    "authentik": {
      "image": "ghcr.io/goauthentik/server",
      "tag": "2026.2.1",
      "container_name": "authentik",
      "dns_alias": "authentik.ai-stack",
      "depends_on": [
        "postgres"
      ],
      "ports": [],
      "volumes": [],
      "environment": {
        "AUTHENTIK_POSTGRESQL__HOST": "postgres.ai-stack",
        "AUTHENTIK_POSTGRESQL__NAME": "aistack",
        "AUTHENTIK_POSTGRESQL__USER": "aistack",
        "AUTHENTIK_ERROR_REPORTING__ENABLED": "false",
        "AUTHENTIK_LOG_LEVEL": "info",
        "AUTHENTIK_LISTEN__TRUSTED_PROXY_CIDRS": "10.89.0.0/24,127.0.0.0/8"
      },
      "secrets": [
        {
          "name": "postgres_password",
          "target": "AUTHENTIK_POSTGRESQL__PASSWORD"
        },
        {
          "name": "authentik_secret_key",
          "target": "AUTHENTIK_SECRET_KEY"
        }
      ],
      "health_check": {
        "command": "curl -sf http://localhost:9000/-/health/live/ || exit 1",
        "interval": "30s",
        "retries": 5,
        "timeout": "10s"
      },
      "resources": {
        "cpus": 2,
        "memory": "2g",
        "gpu": null
      },
      "command": "server"
    },
    "litellm": {
      "image": "ghcr.io/berriai/litellm",
      "tag": "main-v1.81.14-stable",
      "container_name": "litellm",
      "dns_alias": "litellm.ai-stack",
      "depends_on": [
        "postgres"
      ],
      "ports": [],
      "volumes": [
        {
          "host": "$AI_STACK_DIR/configs/litellm/proxy_config.yaml",
          "container": "/app/proxy_config.yaml",
          "mode": "ro"
        },
        {
          "host": "$AI_STACK_DIR/configs/litellm/hooks.py",
          "container": "/app/hooks.py",
          "mode": "ro"
        }
      ],
      "command": "--config /app/proxy_config.yaml",
      "environment": {
        "DATABASE_URL": "postgresql://aistack:@postgres.ai-stack:5432/aistack",
        "KI_BASE_URL": "http://knowledge-index.ai-stack:8100"
      },
      "secrets": [
        {
          "name": "litellm_master_key",
          "target": "LITELLM_MASTER_KEY"
        },
        {
          "name": "postgres_password",
          "target": "POSTGRES_PASSWORD"
        },
        {
          "name": "knowledge_index_api_key",
          "target": "KI_API_KEY"
        },
        {
          "name": "openai_api_key",
          "target": "OPENAI_API_KEY"
        },
        {
          "name": "groq_api_key",
          "target": "GROQ_API_KEY"
        },
        {
          "name": "anthropic_api_key",
          "target": "ANTHROPIC_API_KEY"
        },
        {
          "name": "mistral_api_key",
          "target": "MISTRAL_API_KEY"
        }
      ],
      "health_check": {
        "command": "bash -c 'echo > /dev/tcp/localhost/4000'",
        "interval": "30s",
        "retries": 3,
        "timeout": "5s"
      },
      "resources": {
        "cpus": 2,
        "memory": "2g",
        "gpu": null
      }
    },
    "vllm": {
      "image": "docker.io/vllm/vllm-openai",
      "tag": "v0.17.1",
      "command": "--model /models/qwen2.5-1.5b --served-model-name qwen2.5-1.5b --tensor-parallel-size 1 --max-model-len 2048 --gpu-memory-utilization 0.55 --host 0.0.0.0 --port 8000 --enforce-eager",
      "container_name": "vllm",
      "dns_alias": "vllm.ai-stack",
      "depends_on": [
        "litellm"
      ],
      "ports": [],
      "volumes": [
        {
          "host": "$AI_STACK_DIR/models",
          "container": "/models",
          "mode": "ro"
        }
      ],
      "environment": {
        "MODEL_NAME": "/models/qwen2.5-1.5b",
        "TENSOR_PARALLEL_SIZE": "1",
        "MAX_MODEL_LEN": "2048",
        "GPU_MEMORY_UTILIZATION": "0.55",
        "PYTORCH_ALLOC_CONF": "expandable_segments:True"
      },
      "secrets": [],
      "health_check": {
        "command": "curl -sf http://localhost:8000/health",
        "interval": "60s",
        "retries": 3,
        "timeout": "10s"
      },
      "resources": {
        "cpus": 4,
        "memory": "8g",
        "gpu": "nvidia.com/gpu=all"
      }
    },
    "ollama": {
      "image": "docker.io/ollama/ollama",
      "tag": "0.18.2",
      "container_name": "ollama",
      "dns_alias": "ollama.ai-stack",
      "depends_on": [
        "litellm"
      ],
      "ports": [
        {
          "host": 11434,
          "container": 11434,
          "bind": "127.0.0.1"
        }
      ],
      "volumes": [
        {
          "host": "$AI_STACK_DIR/ollama",
          "container": "/root/.ollama",
          "mode": "rw"
        },
        {
          "host": "$AI_STACK_DIR/models",
          "container": "/gguf",
          "mode": "ro"
        }
      ],
      "environment": {
        "OLLAMA_MAX_LOADED_MODELS": "2",
        "OLLAMA_KEEP_ALIVE": "5m",
        "OLLAMA_NUM_PARALLEL": "1"
      },
      "secrets": [],
      "health_check": {
        "command": "bash -c 'echo > /dev/tcp/localhost/11434'",
        "interval": "30s",
        "retries": 3,
        "timeout": "5s"
      },
      "resources": {
        "cpus": null,
        "memory": null,
        "gpu": "nvidia.com/gpu=0"
      }
    },
    "flowise": {
      "image": "docker.io/flowiseai/flowise",
      "tag": "3.0.13",
      "container_name": "flowise",
      "dns_alias": "flowise.ai-stack",
      "depends_on": [
        "litellm",
        "qdrant"
      ],
      "ports": [],
      "volumes": [
        {
          "host": "$AI_STACK_DIR/flowise",
          "container": "/data/flowise",
          "mode": "rw"
        }
      ],
      "environment": {
        "FLOWISE_USERNAME": "admin",
        "DATABASE_PATH": "/data/flowise"
      },
      "secrets": [
        {
          "name": "flowise_password",
          "target": "FLOWISE_PASSWORD"
        },
        {
          "name": "flowise_secret_key",
          "target": "FLOWISE_SECRETKEY_OVERWRITE"
        }
      ],
      "health_check": {
        "command": "curl -sf http://localhost:3000/api/v1/ping || exit 1",
        "interval": "30s",
        "retries": 3,
        "timeout": "5s"
      },
      "resources": {
        "cpus": 1,
        "memory": "1g",
        "gpu": null
      }
    },
    "openwebui": {
      "image": "ghcr.io/open-webui/open-webui",
      "tag": "v0.8.10",
      "container_name": "openwebui",
      "dns_alias": "webui.ai-stack",
      "depends_on": [
        "litellm"
      ],
      "ports": [],
      "volumes": [
        {
          "host": "$AI_STACK_DIR/openwebui",
          "container": "/app/backend/data",
          "mode": "rw"
        }
      ],
      "environment": {
        "OPENAI_API_BASE": "http://litellm.ai-stack:4000",
        "OLLAMA_BASE_URL": "http://ollama.ai-stack:11434"
      },
      "secrets": [
        {
          "name": "openwebui_api_key",
          "target": "OPENAI_API_KEY"
        }
      ],
      "health_check": {
        "command": "curl -sf http://localhost:8080/health",
        "interval": "30s",
        "retries": 3,
        "timeout": "5s"
      },
      "resources": {
        "cpus": 1,
        "memory": "2g",
        "gpu": null
      }
    },
    "prometheus": {
      "image": "docker.io/prom/prometheus",
      "tag": "v3.10.0",
      "container_name": "prometheus",
      "dns_alias": "prometheus.ai-stack",
      "depends_on": [],
      "ports": [],
      "volumes": [
        {
          "host": "$AI_STACK_DIR/configs/prometheus",
          "container": "/etc/prometheus",
          "mode": "ro"
        }
      ],
      "environment": {},
      "secrets": [],
      "health_check": {
        "command": "wget -qO- http://localhost:9090/-/healthy || exit 1",
        "interval": "30s",
        "retries": 3,
        "timeout": "5s"
      },
      "resources": {
        "cpus": 1,
        "memory": "2g",
        "gpu": null
      }
    },
    "grafana": {
      "image": "docker.io/grafana/grafana",
      "tag": "12.4.0",
      "container_name": "grafana",
      "dns_alias": "grafana.ai-stack",
      "depends_on": [
        "prometheus"
      ],
      "ports": [],
      "volumes": [
        {
          "host": "$AI_STACK_DIR/configs/grafana",
          "container": "/etc/grafana",
          "mode": "ro"
        },
        {
          "host": "$AI_STACK_DIR/grafana",
          "container": "/var/lib/grafana",
          "mode": "rw"
        }
      ],
      "environment": {},
      "secrets": [],
      "health_check": {
        "command": "curl -sf http://localhost:3000/api/health",
        "interval": "30s",
        "retries": 3,
        "timeout": "5s"
      },
      "resources": {
        "cpus": 1,
        "memory": "1g",
        "gpu": null
      }
    },
    "loki": {
      "image": "docker.io/grafana/loki",
      "tag": "3.6.7",
      "container_name": "loki",
      "dns_alias": "loki.ai-stack",
      "depends_on": [],
      "ports": [],
      "volumes": [
        {
          "host": "$AI_STACK_DIR/configs/loki",
          "container": "/etc/loki",
          "mode": "ro"
        },
        {
          "host": "$AI_STACK_DIR/logs/loki",
          "container": "/loki",
          "mode": "rw"
        }
      ],
      "environment": {},
      "secrets": [],
      "health_check": {
        "command": null,
        "interval": "30s",
        "retries": 3,
        "timeout": "5s"
      },
      "resources": {
        "cpus": 1,
        "memory": "2g",
        "gpu": null
      }
    },
    "promtail": {
      "image": "docker.io/grafana/promtail",
      "tag": "3.6.7",
      "container_name": "promtail",
      "dns_alias": "promtail.ai-stack",
      "depends_on": [
        "loki"
      ],
      "ports": [],
      "volumes": [
        {
          "host": "$AI_STACK_DIR/configs/promtail",
          "container": "/etc/promtail",
          "mode": "ro"
        },
        {
          "host": "$AI_STACK_DIR/logs",
          "container": "/data/logs",
          "mode": "ro"
        }
      ],
      "environment": {},
      "secrets": [],
      "health_check": {
        "command": "bash -c 'echo > /dev/tcp/localhost/9080'",
        "interval": "30s",
        "retries": 3,
        "timeout": "5s"
      },
      "resources": {
        "cpus": 1,
        "memory": "1g",
        "gpu": null
      }
    },
    "minio": {
      "image": "docker.io/minio/minio",
      "tag": "RELEASE.2025-04-22T22-12-26Z",
      "container_name": "minio",
      "dns_alias": "minio.ai-stack",
      "depends_on": [],
      "ports": [],
      "volumes": [
        {
          "host": "$AI_STACK_DIR/minio",
          "container": "/data",
          "mode": "rw"
        }
      ],
      "environment": {},
      "secrets": [
        {
          "name": "minio_root_user",
          "target": "MINIO_ROOT_USER"
        },
        {
          "name": "minio_root_password",
          "target": "MINIO_ROOT_PASSWORD"
        }
      ],
      "command": "server /data --console-address :9001",
      "buckets": [
        "documents",
        "outputs",
        "research",
        "libraries"
      ],
      "service_accounts": [
        {
          "name": "ki-service",
          "description": "knowledge-index read/write account",
          "secret_access_key": "minio_ki_access_key",
          "secret_secret_key": "minio_ki_secret_key",
          "policy": {
            "read": [
              "documents",
              "libraries"
            ],
            "write": [
              "outputs",
              "research"
            ]
          }
        }
      ],
      "health_check": {
        "command": "bash -c 'curl -sf http://localhost:9000/minio/health/live'",
        "interval": "30s",
        "retries": 5,
        "timeout": "5s"
      },
      "resources": {
        "cpus": 1,
        "memory": "1g",
        "gpu": null
      }
    },
    "homepage": {
      "image": "ghcr.io/gethomepage/homepage",
      "tag": "latest",
      "container_name": "homepage",
      "dns_alias": "homepage.ai-stack",
      "depends_on": [],
      "ports": [],
      "volumes": [
        {
          "host": "$AI_STACK_DIR/configs/homepage",
          "container": "/app/config",
          "mode": "ro"
        }
      ],
      "environment": {
        "HOMEPAGE_ALLOWED_HOSTS": "homepage.ai-stack,homepage.ai-stack:3000,dashboard.stack.localhost,dashboard.localhost,localhost,localhost:3000,127.0.0.1,127.0.0.1:3002"
      },
      "secrets": [],
      "health_check": {
        "command": "wget -qO- http://localhost:3000/api/healthcheck || exit 1",
        "interval": "30s",
        "retries": 3,
        "timeout": "5s"
      },
      "resources": {
        "cpus": 0.5,
        "memory": "256m",
        "gpu": null
      }
    },
    "m2m-gateway": {
      "image": "localhost/m2m-gateway",
      "tag": "0.1.0",
      "container_name": "m2m-gateway",
      "dns_alias": "m2m-gateway.ai-stack",
      "depends_on": [
        "authentik",
        "knowledge-index",
        "litellm"
      ],
      "ports": [
        {
          "host": 8787,
          "container": 8787,
          "bind": "127.0.0.1"
        }
      ],
      "volumes": [],
      "environment": {
        "M2M_JWT_AUDIENCE": "local-m2m-gateway",
        "M2M_JWT_ALGORITHM": "HS256",
        "M2M_JWT_ISSUER": "",
        "M2M_JWKS_URL": "",
