{
  "schema_version": "1.0",
  "ai_stack_dir": "$HOME/ai-stack",
  "network": {
    "name": "ai-stack-net",
    "driver": "bridge",
    "internal": false
  },
  "node_profile": "controller",
  "nodes": [
    {
      "name": "workstation",
      "profile": "controller",
      "address": null,
      "address_fallback": null,
      "os": "linux",
      "deployment": "podman",
      "models": ["llama3.1:8b", "qwen2.5-1.5b"]
    },
    {
      "name": "macbook-m1",
      "profile": "inference-worker",
      "address": "TC25.mynetworksettings.com",
      "address_fallback": "10.19.208.118",
      "os": "darwin",
      "deployment": "bare_metal",
      "models": ["llama3.1:8b-instruct-q4_K_M"]
    },
    {
      "name": "alienware",
      "profile": "inference-worker",
      "address": "SOL.mynetworksettings.com",
      "address_fallback": "10.19.208.113",
      "os": "linux",
      "deployment": "podman",
      "models": ["llama3.2:3b-instruct-q4_K_M"]
    }
  ],
  "models": [
    {
      "name": "llama3.1:8b",
      "backend": "ollama",
      "device": "cpu"
    },
    {
      "name": "qwen2.5-1.5b",
      "backend": "vllm",
      "device": "gpu",
      "repo": "Qwen/Qwen2.5-1.5B-Instruct",
      "quantization": null
    },
    {
      "name": "llama3.1:8b-instruct-q4_K_M",
      "backend": "ollama",
      "device": "gpu",
      "host": "macbook-m1"
    },
    {
      "name": "llama3.2:3b-instruct-q4_K_M",
      "backend": "ollama",
      "device": "gpu",
      "host": "alienware"
    }
  ],
  "services": {
    "traefik": {
      "image": "docker.io/library/traefik",
      "tag": "v3.6.10",
      "container_name": "traefik",
      "dns_alias": "traefik.ai-stack",
      "depends_on": [],
      "ports": [
        {
          "host": 80,
          "container": 80,
          "bind": "0.0.0.0"
        },
        {
          "host": 443,
          "container": 443,
          "bind": "0.0.0.0"
        },
        {
          "host": 8080,
          "container": 8080,
          "bind": "127.0.0.1"
        }
      ],
      "volumes": [
        {
          "host": "$AI_STACK_DIR/configs/traefik/traefik.yaml",
          "container": "/etc/traefik/traefik.yaml",
          "mode": "ro"
        },
        {
          "host": "$AI_STACK_DIR/configs/traefik/dynamic",
          "container": "/etc/traefik/dynamic",
          "mode": "ro"
        },
        {
          "host": "$AI_STACK_DIR/configs/tls",
          "container": "/etc/traefik/tls",
          "mode": "ro"
        }
      ],
      "environment": {},
      "secrets": [],
      "health_check": {
        "command": "wget -qO- http://localhost:8080/ping || exit 1",
        "interval": "30s",
        "retries": 3,
        "timeout": "5s"
      },
      "resources": {
        "cpus": 0.5,
        "memory": "256m",
        "gpu": null
      }
    },
    "postgres": {
      "image": "docker.io/library/postgres",
      "tag": "17.9",
      "container_name": "postgres",
      "dns_alias": "postgres.ai-stack",
      "depends_on": [],
      "ports": [
        {
          "host": 5432,
          "container": 5432,
          "bind": "127.0.0.1"
        }
      ],
      "volumes": [
        {
          "host": "$AI_STACK_DIR/postgres",
          "container": "/var/lib/postgresql/data",
          "mode": "rw"
        }
      ],
      "environment": {
        "POSTGRES_USER": "aistack",
        "POSTGRES_DB": "aistack"
      },
      "secrets": [
        {
          "name": "postgres_password",
          "target": "POSTGRES_PASSWORD"
        }
      ],
      "health_check": {
        "command": "pg_isready -U aistack",
        "interval": "30s",
        "retries": 3,
        "timeout": "5s"
      },
      "resources": {
        "cpus": 2,
        "memory": "4g",
        "gpu": null
      }
    },
    "qdrant": {
      "image": "docker.io/qdrant/qdrant",
      "tag": "v1.17.0",
      "container_name": "qdrant",
      "dns_alias": "qdrant.ai-stack",
      "depends_on": [],
      "ports": [
        {
          "host": 6333,
          "container": 6333,
          "bind": "127.0.0.1"
        },
        {
          "host": 6334,
          "container": 6334,
          "bind": "127.0.0.1"
        }
      ],
      "volumes": [
        {
          "host": "$AI_STACK_DIR/qdrant",
          "container": "/qdrant/storage",
          "mode": "rw"
        }
      ],
      "environment": {},
      "secrets": [
        {
          "name": "qdrant_api_key",
          "target": "QDRANT__SERVICE__API_KEY"
        }
      ],
      "health_check": {
        "command": "bash -c 'echo > /dev/tcp/localhost/6333'",
        "interval": "30s",
        "retries": 3,
        "timeout": "5s"
      },
      "resources": {
        "cpus": 2,
        "memory": "8g",
        "gpu": null
      }
    },
    "knowledge-index": {
      "image": "localhost/knowledge-index",
      "tag": "0.1.0",
      "container_name": "knowledge-index",
      "dns_alias": "knowledge-index.ai-stack",
      "depends_on": [
        "postgres",
        "qdrant"
      ],
      "ports": [
        {
          "host": 8100,
          "container": 8100,
          "bind": "127.0.0.1"
        }
      ],
      "volumes": [
        {
          "host": "$AI_STACK_DIR/libraries",
          "container": "/libraries",
          "mode": "ro"
        }
      ],
      "environment": {
        "DATABASE_URL": "postgresql://aistack:@postgres.ai-stack:5432/aistack",
        "QDRANT_HOST": "qdrant.ai-stack",
        "QDRANT_PORT": "6333",
        "ROUTE_CACHE_TTL": "60",
        "LISTEN_PORT": "8100"
      },
      "secrets": [
        {
          "name": "postgres_password",
          "target": "POSTGRES_PASSWORD"
        },
        {
          "name": "qdrant_api_key",
          "target": "QDRANT_API_KEY"
        }
      ],
      "health_check": {
        "command": "bash -c 'echo > /dev/tcp/localhost/8100'",
        "interval": "30s",
        "retries": 3,
        "timeout": "5s"
      },
      "mcp": {
        "sse_endpoint": "/mcp/sse",
        "message_endpoint": "/mcp/messages",
        "tools": ["search_knowledge", "ingest_document"],
        "transport": "http-sse"
      },
      "resources": {
        "cpus": 1,
        "memory": "512m",
        "gpu": null
      }
    },
    "authentik": {
      "image": "ghcr.io/goauthentik/server",
      "tag": "2026.2.1",
      "container_name": "authentik",
      "dns_alias": "authentik.ai-stack",
      "depends_on": [
        "postgres"
      ],
      "ports": [],
      "volumes": [],
      "environment": {
        "AUTHENTIK_POSTGRESQL__HOST": "postgres.ai-stack",
        "AUTHENTIK_POSTGRESQL__NAME": "aistack",
        "AUTHENTIK_POSTGRESQL__USER": "aistack",
        "AUTHENTIK_ERROR_REPORTING__ENABLED": "false",
        "AUTHENTIK_LOG_LEVEL": "info"
      },
      "secrets": [
        {
          "name": "postgres_password",
          "target": "AUTHENTIK_POSTGRESQL__PASSWORD"
        },
        {
          "name": "authentik_secret_key",
          "target": "AUTHENTIK_SECRET_KEY"
        }
      ],
      "health_check": {
        "command": "curl -sf http://localhost:9000/-/health/live/ || exit 1",
        "interval": "30s",
        "retries": 5,
        "timeout": "10s"
      },
      "resources": {
        "cpus": 2,
        "memory": "2g",
        "gpu": null
      },
      "command": "server"
    },
    "litellm": {
      "image": "ghcr.io/berriai/litellm",
      "tag": "main-v1.81.14-stable",
      "container_name": "litellm",
      "dns_alias": "litellm.ai-stack",
      "depends_on": [
        "postgres"
      ],
      "ports": [
        {
          "host": 9000,
          "container": 4000,
          "bind": "127.0.0.1"
        }
      ],
      "volumes": [],
      "environment": {
        "DATABASE_URL": "postgresql://aistack:@postgres.ai-stack:5432/aistack"
      },
      "secrets": [
        {
          "name": "litellm_master_key",
          "target": "LITELLM_MASTER_KEY"
        },
        {
          "name": "postgres_password",
          "target": "POSTGRES_PASSWORD"
        }
      ],
      "health_check": {
        "command": "bash -c 'echo > /dev/tcp/localhost/4000'",
        "interval": "30s",
        "retries": 3,
        "timeout": "5s"
      },
      "resources": {
        "cpus": 2,
        "memory": "2g",
        "gpu": null
      }
    },
    "vllm": {
      "image": "docker.io/vllm/vllm-openai",
      "tag": "v0.17.1",
      "command": "--model /models/qwen2.5-1.5b --served-model-name qwen2.5-1.5b --tensor-parallel-size 1 --max-model-len 2048 --gpu-memory-utilization 0.55 --host 0.0.0.0 --port 8000 --enforce-eager",
      "container_name": "vllm",
      "dns_alias": "vllm.ai-stack",
      "depends_on": [
        "litellm"
      ],
      "ports": [
        {
          "host": 8000,
          "container": 8000
        }
      ],
      "volumes": [
        {
          "host": "$AI_STACK_DIR/models",
          "container": "/models",
          "mode": "ro"
        }
      ],
      "environment": {
        "MODEL_NAME": "/models/qwen2.5-1.5b",
        "TENSOR_PARALLEL_SIZE": "1",
        "MAX_MODEL_LEN": "2048",
        "GPU_MEMORY_UTILIZATION": "0.55",
        "PYTORCH_ALLOC_CONF": "expandable_segments:True"
      },
      "secrets": [],
      "health_check": {
        "command": "curl -sf http://localhost:8000/health",
        "interval": "60s",
        "retries": 3,
        "timeout": "10s"
      },
      "resources": {
        "cpus": 4,
        "memory": "8g",
        "gpu": "nvidia.com/gpu=all"
      }
    },
    "ollama": {
      "image": "docker.io/ollama/ollama",
      "tag": "0.18.2",
      "container_name": "ollama",
      "dns_alias": "ollama.ai-stack",
      "depends_on": [
        "litellm"
      ],
      "ports": [],
      "volumes": [
        {
          "host": "$AI_STACK_DIR/ollama",
          "container": "/root/.ollama",
          "mode": "rw"
        },
        {
          "host": "$AI_STACK_DIR/models",
          "container": "/gguf",
          "mode": "ro"
        }
      ],
      "environment": {},
      "secrets": [],
      "health_check": {
        "command": "bash -c 'echo > /dev/tcp/localhost/11434'",
        "interval": "30s",
        "retries": 3,
        "timeout": "5s"
      },
      "resources": {
        "cpus": 4,
        "memory": "16g",
        "gpu": "nvidia.com/gpu=all"
      }
    },
    "flowise": {
      "image": "docker.io/flowiseai/flowise",
      "tag": "3.0.13",
      "container_name": "flowise",
      "dns_alias": "flowise.ai-stack",
      "depends_on": [
        "litellm",
        "qdrant"
      ],
      "ports": [
        {
          "host": 3001,
          "container": 3000,
          "bind": "127.0.0.1"
        }
      ],
      "volumes": [
        {
          "host": "$AI_STACK_DIR/flowise",
          "container": "/data/flowise",
          "mode": "rw"
        }
      ],
      "environment": {
        "FLOWISE_USERNAME": "admin",
        "DATABASE_PATH": "/data/flowise"
      },
      "secrets": [
        {
          "name": "flowise_password",
          "target": "FLOWISE_PASSWORD"
        },
        {
          "name": "flowise_secret_key",
          "target": "FLOWISE_SECRETKEY_OVERWRITE"
        }
      ],
      "health_check": {
        "command": "curl -sf http://localhost:3000/api/v1/ping || exit 1",
        "interval": "30s",
        "retries": 3,
        "timeout": "5s"
      },
      "resources": {
        "cpus": 1,
        "memory": "1g",
        "gpu": null
      }
    },
    "openwebui": {
      "image": "ghcr.io/open-webui/open-webui",
      "tag": "v0.8.10",
      "container_name": "openwebui",
      "dns_alias": "webui.ai-stack",
      "depends_on": [
        "litellm"
      ],
      "ports": [
        {
          "host": 9090,
          "container": 8080,
          "bind": "127.0.0.1"
        }
      ],
      "volumes": [
        {
          "host": "$AI_STACK_DIR/openwebui",
          "container": "/app/backend/data",
          "mode": "rw"
        }
      ],
      "environment": {
        "OPENAI_API_BASE": "http://litellm.ai-stack:4000",
        "OLLAMA_BASE_URL": "http://ollama.ai-stack:11434"
      },
      "secrets": [
        {
          "name": "openwebui_api_key",
          "target": "OPENAI_API_KEY"
        }
      ],
      "health_check": {
        "command": "curl -sf http://localhost:8080/health",
        "interval": "30s",
        "retries": 3,
        "timeout": "5s"
      },
      "resources": {
        "cpus": 1,
        "memory": "1g",
        "gpu": null
      }
    },
    "prometheus": {
      "image": "docker.io/prom/prometheus",
      "tag": "v3.10.0",
      "container_name": "prometheus",
      "dns_alias": "prometheus.ai-stack",
      "depends_on": [],
      "ports": [
        {
          "host": 9091,
          "container": 9090,
          "bind": "127.0.0.1"
        }
      ],
      "volumes": [
        {
          "host": "$AI_STACK_DIR/configs/prometheus",
          "container": "/etc/prometheus",
          "mode": "ro"
        }
      ],
      "environment": {},
      "secrets": [],
      "health_check": {
        "command": "wget -qO- http://localhost:9090/-/healthy || exit 1",
        "interval": "30s",
        "retries": 3,
        "timeout": "5s"
      },
      "resources": {
        "cpus": 1,
        "memory": "2g",
        "gpu": null
      }
    },
    "grafana": {
      "image": "docker.io/grafana/grafana",
      "tag": "12.4.0",
      "container_name": "grafana",
      "dns_alias": "grafana.ai-stack",
      "depends_on": [
        "prometheus"
      ],
      "ports": [
        {
          "host": 3000,
          "container": 3000,
          "bind": "127.0.0.1"
        }
      ],
      "volumes": [
        {
          "host": "$AI_STACK_DIR/configs/grafana",
          "container": "/etc/grafana",
          "mode": "ro"
        },
        {
          "host": "$AI_STACK_DIR/grafana",
          "container": "/var/lib/grafana",
          "mode": "rw"
        }
      ],
      "environment": {},
      "secrets": [],
      "health_check": {
        "command": "curl -sf http://localhost:3000/api/health",
        "interval": "30s",
        "retries": 3,
        "timeout": "5s"
      },
      "resources": {
        "cpus": 1,
        "memory": "1g",
        "gpu": null
      }
    },
    "loki": {
      "image": "docker.io/grafana/loki",
      "tag": "3.6.7",
      "container_name": "loki",
      "dns_alias": "loki.ai-stack",
      "depends_on": [],
      "ports": [
        {
          "host": 3100,
          "container": 3100,
          "bind": "127.0.0.1"
        }
      ],
      "volumes": [
        {
          "host": "$AI_STACK_DIR/configs/loki",
          "container": "/etc/loki",
          "mode": "ro"
        },
        {
          "host": "$AI_STACK_DIR/logs/loki",
          "container": "/loki",
          "mode": "rw"
        }
      ],
      "environment": {},
      "secrets": [],
      "health_check": {
        "command": null,
        "interval": "30s",
        "retries": 3,
        "timeout": "5s"
      },
      "resources": {
        "cpus": 1,
        "memory": "2g",
        "gpu": null
      }
    },
    "promtail": {
      "image": "docker.io/grafana/promtail",
      "tag": "3.6.7",
      "container_name": "promtail",
      "dns_alias": "promtail.ai-stack",
      "depends_on": [
        "loki"
      ],
      "ports": [],
      "volumes": [
        {
          "host": "$AI_STACK_DIR/configs/promtail",
          "container": "/etc/promtail",
          "mode": "ro"
        },
        {
          "host": "$AI_STACK_DIR/logs",
          "container": "/data/logs",
          "mode": "ro"
        }
      ],
      "environment": {},
      "secrets": [],
      "health_check": {
        "command": "bash -c 'echo > /dev/tcp/localhost/9080'",
        "interval": "30s",
        "retries": 3,
        "timeout": "5s"
      },
      "resources": {
        "cpus": 1,
        "memory": "1g",
        "gpu": null
      }
    }
  }
}
